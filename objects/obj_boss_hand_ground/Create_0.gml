#region Inicialização da mão ativa
hand_speed = 0.1;    // velocidade de subida, vai ser sobrescrita pelo boss
is_target = false;   // se é a mão correta ou errada
owner = noone;       // referência para o boss
spawn_x = x;         // posição inicial X
spawn_y = y;         // posição inicial Y
target_y = y;        // posição final Y
#endregion